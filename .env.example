# Paperless-ngx Configuration
PAPERLESS_URL=http://localhost:8000
PAPERLESS_TOKEN=your_api_token_here

# LLM Configuration (for document classification)
LLM_PROVIDER=ollama
LLM_MODEL=qwen2.5:7b
LLM_API_BASE=http://localhost:11434
LLM_API_KEY=

# Vision/OCR Configuration
ENABLE_VISION=true
LLM_PROVIDER_VISION=ollama
LLM_MODEL_VISION=qwen2.5vl:7b
LLM_API_BASE_VISION=http://localhost:11434
ENABLE_FALLBACK_OCR=true
FORCE_OCR_TAG=force-ocr
FORCE_OCR_FIX_TAG=force-ocr-fix
OCR_POST_PROCESS=true

# Processing Configuration
PROCESS_TAG=ai-process
PROCESSED_TAG=ai-processed

# Database
DATABASE_URL=sqlite:///./data/paperless_ai_agent.db
