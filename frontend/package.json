    "eslint-plugin-react-refresh": "^0.5.2",
    "jsdom": "^29.0.2",
    "postcss": "^8.4.35",
    "prettier": "^3.8.3",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.58.2",
    "vite": "^5.1.0",
    "vitest": "^4.1.4"
